#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

ynh_systemd_action --service_name=$app --action="stop" 2>/dev/null || true
yunohost service remove $app 2>/dev/null || true

ynh_remove_systemd_config
ynh_remove_nginx_config
ynh_remove_nodejs

# apt packages (git, redis-server, build-essential, python3, libpq-dev) and
# the postgresql database are torn down automatically by the apt/database
# resources declared in manifest.toml.

ynh_secure_remove --file="/var/log/$app"
