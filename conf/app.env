NODE_ENV=production
APPLICATION_PORT=__PORT__

# Public URLs — see scripts/install for how these are derived from
# domain+path. AUTH_ORIGIN is the frontend's browser Origin (no path,
# origins never include one). BETTER_AUTH_URL/VITE_APP_API_HTTP are the
# same value: the base the browser hits, which nginx forwards to /api/
# on the backend, matching the backend's own internal /api/v1 routes.
AUTH_ORIGIN=__AUTH_ORIGIN__
BETTER_AUTH_URL=__PUBLIC_BASE_URL__

# Secrets — generated once at install, preserved across upgrades
APPLICATION_JWT_SECRET=__JWT_SECRET__
APP_SESSION_ID_SECRET=__SESSION_SECRET__
BETTER_AUTH_SECRET=__BETTER_AUTH_SECRET__

# Database (provisioned by the postgresql resource)
APPLICATION_DB_HOST=localhost
APPLICATION_DB_PORT=5432
APPLICATION_DB_USERNAME=__DB_USER__
APPLICATION_DB_PASSWORD=__DB_PWD__
APPLICATION_DB_DATABASE=__DB_NAME__

# Redis (shared system redis-server, dedicated logical DB — see _common.sh)
APPLICATION_REDIS_HOST=127.0.0.1
APPLICATION_REDIS_PORT=6379
APPLICATION_REDIS_DB=__REDIS_DB__

# Optional features are left unset on purpose. Add any of RESEND_API_KEY,
# GOOGLE_CLIENT_ID/SECRET, GITHUB_CLIENT_ID/SECRET, POLYGON_API_KEY,
# ALPHA_VANTAGE_API_KEY, FMP_API_KEY, ANTHROPIC_API_KEY, ADMIN_USERS, etc.
# here as needed, then `systemctl restart __APP__`.
